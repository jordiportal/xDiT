# xDiT Service — Environment variables
# Copy to .env and adjust for your setup

# Path to HuggingFace models on the host
MODELS_PATH=/data/models

# Model to load (HF name or path inside /models)
XDIT_MODEL=/models/FLUX.1-dev

# Number of GPUs
XDIT_WORLD_SIZE=4

# Parallelism config (ulysses × ring × cfg must = world_size)
XDIT_ULYSSES=2
XDIT_RING=1
XDIT_PIPEFUSION=1

# Set to empty string to disable CFG parallel
XDIT_CFG_FLAG=--use_cfg_parallel

# Host port
XDIT_PORT=6000
